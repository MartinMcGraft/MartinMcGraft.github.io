---
import { Globe } from "@lucide/astro";
import { education } from "../../data/education";
---

<section
  id="education-section"
  class="flex flex-col gap-6 py-10 sm:gap-8 lg:py-12"
>
  <section class="flex flex-col gap-3">
    <h2 class="text-3xl font-bold leading-tight text-[var(--colour-cloud)] sm:text-4xl">
      {education.title}
    </h2>
  </section>

  <section class="grid gap-4">
    {education.items.map((item) => (
      <article class="rounded-lg border border-[var(--colour-slate)] bg-[var(--colour-navy)] p-5 sm:p-6">
        <section class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
          <section>
            <h3 class="text-xl font-bold text-[var(--colour-cloud)]">
              <a
                href={item.href}
                target="_blank"
                rel="noreferrer"
                class="inline-flex items-center gap-2 transition hover:text-[var(--colour-mist)]"
              >
                <span>{item.institution}</span>
                <Globe size={18} aria-hidden="true" />
              </a>
            </h3>
            <p class="text-sm font-medium text-[var(--colour-mist)]">{item.degree}</p>
          </section>
          <section class="text-sm font-semibold text-[var(--colour-mist)] sm:text-right">
            <p>{item.period}</p>
            <p>{item.location}</p>
          </section>
        </section>

        {item.details.length > 0 && (
          <ul class="mt-4 grid gap-2 text-base leading-7 text-[color-mix(in_srgb,var(--colour-cloud)_80%,transparent)]">
            {item.details.map((detail) => (
              <li class="flex gap-3">
                <span class="mt-3 h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--colour-mist)]"></span>
                <span>{detail}</span>
              </li>
            ))}
          </ul>
        )}
      </article>
    ))}
  </section>
</section>
