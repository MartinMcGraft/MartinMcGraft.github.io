---
import { Globe } from "@lucide/astro";
import { projects } from "../../data/projects";
---

<section
  id="projects-section"
  class="flex flex-col gap-6 py-10 sm:gap-8 lg:py-12"
>
  <section class="flex flex-col gap-3">
    <h2 class="text-3xl font-bold leading-tight text-[var(--colour-cloud)] sm:text-4xl">
      {projects.title}
    </h2>
  </section>

  <section class="grid gap-4 xl:grid-cols-2">
    {projects.items.map((project) => (
      <article class="flex min-h-72 flex-col justify-between rounded-lg border border-[var(--colour-slate)] bg-[var(--colour-navy)] p-5 sm:p-6">
        <section class="flex flex-col gap-4">
          <section>
            <section class="flex flex-wrap items-center gap-2">
              <h3 class="text-xl font-bold text-[var(--colour-cloud)]">
                <a
                  href={project.href ?? projects.defaultHref}
                  target="_blank"
                  rel="noreferrer"
                  class="inline-flex items-center gap-2 transition hover:text-[var(--colour-mist)]"
                >
                  <span>{project.name}</span>
                  <Globe size={18} aria-hidden="true" />
                </a>
              </h3>
              {project.status && (
                <span class="rounded-lg bg-[var(--colour-slate)] px-2.5 py-1 text-xs font-bold uppercase tracking-[0.12em] text-[var(--colour-mist)]">
                  {project.status}
                </span>
              )}
            </section>
            <p class="mt-1 text-sm font-medium text-[var(--colour-mist)]">{project.subtitle}</p>
          </section>

          <ul class="grid gap-2 text-base leading-7 text-[color-mix(in_srgb,var(--colour-cloud)_80%,transparent)]">
            {project.details.map((detail) => (
              <li class="flex gap-3">
                <span class="mt-3 h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--colour-mist)]"></span>
                <span>{detail}</span>
              </li>
            ))}
          </ul>
        </section>

        <section class="mt-6 flex flex-wrap gap-2">
          {project.tags.map((tag) => (
            <span class="rounded-lg border border-[var(--colour-slate)] px-3 py-2 text-xs font-semibold uppercase tracking-[0.12em] text-[var(--colour-mist)]">
              {tag}
            </span>
          ))}
        </section>
      </article>
    ))}
  </section>
</section>
