---
import { Download } from "@lucide/astro";
import { resume } from "../../data/resume";

const buttonClass =
  "inline-flex min-h-12 items-center justify-center gap-2 rounded-lg bg-[var(--colour-cloud)] px-4 py-3 text-sm font-bold text-[var(--colour-ink)] transition hover:bg-white";

const base = import.meta.env.BASE_URL;
---

<section
  id="resume-section"
  class="flex flex-col gap-2"
>
  <section class="flex flex-col">
    <h2 class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--colour-mist)]">
      {resume.title}
    </h2>
  </section>

  <section class="grid gap-2 sm:grid-cols-2">
    {resume.downloads.map((download) => (
      <a
        href={`${base}${download.href}`}
        download
        class={buttonClass}
      >
        <Download size={16} aria-hidden="true" />
        {download.label}
      </a>
    ))}
  </section>
</section>
