---
import { Globe, Mail, MapPin, Phone } from "@lucide/astro";
import { contacts } from "../../data/contacts";

const contactItemClass =
  "flex min-h-12 items-center gap-3 rounded-lg border border-[var(--colour-slate)] bg-[color-mix(in_srgb,var(--colour-ink)_45%,transparent)] px-4 py-3 text-sm leading-6 text-[var(--colour-cloud)] transition hover:border-[var(--colour-mist)] hover:bg-[var(--colour-slate)]";
const iconClass = "shrink-0 text-[var(--colour-mist)]";
const brandIconClass = "h-[18px] w-[18px] shrink-0 text-[var(--colour-mist)]";
---

<section
  id="contacts-section"
  class="flex flex-col gap-2 pb-8"
>
  <h2 class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--colour-mist)]">
    {contacts.title}
  </h2>

  <section id="contacts-card" class="grid gap-2">
    {contacts.items.map((item) => {
      const content = (
        <>
          {item.type === "phone" && <Phone size={18} class={iconClass} />}
          {item.type === "email" && <Mail size={18} class={iconClass} />}
          {item.type === "location" && <MapPin size={18} class={iconClass} />}
          {item.type === "portfolio" && <Globe size={18} class={iconClass} />}
          {item.type === "github" && (
            <svg
              class={brandIconClass}
              viewBox="0 0 24 24"
              aria-hidden="true"
              fill="currentColor"
            >
              <path d="M12 .5C5.65.5.5 5.66.5 12.03c0 5.1 3.3 9.43 7.88 10.96.58.1.79-.25.79-.56 0-.28-.01-1.2-.02-2.17-3.2.7-3.88-1.36-3.88-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.2 1.77 1.2 1.03 1.78 2.7 1.27 3.36.97.1-.75.4-1.27.72-1.56-2.56-.29-5.26-1.29-5.26-5.76 0-1.27.45-2.3 1.19-3.11-.12-.3-.52-1.5.11-3.12 0 0 .98-.31 3.2 1.19a11.1 11.1 0 0 1 5.82 0c2.22-1.5 3.2-1.19 3.2-1.19.63 1.62.23 2.82.11 3.12.74.81 1.19 1.84 1.19 3.11 0 4.49-2.7 5.46-5.28 5.75.41.36.77 1.08.77 2.18 0 1.57-.01 2.83-.01 3.22 0 .31.21.67.8.56A11.54 11.54 0 0 0 23.5 12.03C23.5 5.66 18.35.5 12 .5Z" />
            </svg>
          )}
          {item.type === "linkedin" && (
            <svg
              class={brandIconClass}
              viewBox="0 0 24 24"
              aria-hidden="true"
              fill="currentColor"
            >
              <path d="M4.98 3.5A2.48 2.48 0 1 0 5 8.46 2.48 2.48 0 0 0 4.98 3.5ZM2.75 9h4.46v12H2.75Zm7.25 0h4.28v1.64h.06c.6-1.13 2.05-2.32 4.22-2.32 4.51 0 5.34 2.97 5.34 6.84V21h-4.46v-5.13c0-1.22-.02-2.8-1.7-2.8-1.7 0-1.96 1.33-1.96 2.71V21H10Z" />
            </svg>
          )}
          <span class="break-words">{item.label}</span>
        </>
      );

      return item.href ? (
        <a
          href={item.href}
          target={item.href.startsWith("http") ? "_blank" : undefined}
          rel={item.href.startsWith("http") ? "noopener noreferrer" : undefined}
          class={contactItemClass}
        >
          {content}
        </a>
      ) : (
        <section class={contactItemClass}>{content}</section>
      );
    })}
  </section>
</section>
